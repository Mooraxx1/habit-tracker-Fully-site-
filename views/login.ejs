<%- include('partials/header') %>

<div class="card" style="max-width: 500px; margin: 4rem auto 2rem; box-shadow: var(--shadow); border: 1px solid var(--border);">
    
    <h1 style="text-align: center; margin-bottom: 2.5rem; color: var(--text-main); font-weight: 800; letter-spacing: -0.5px;">Account Sign In</h1>
    
    <form action="/auth/login" method="POST">
        <div class="form-group">
            <label for="loginUsername" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Username</label>
            <input type="text" id="loginUsername" name="username" placeholder="Enter your username" style="margin-top: 8px;" required>
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem;">
            <label for="loginPassword" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Password</label>
            <input type="password" id="loginPassword" name="password" placeholder="Enter secure password credentials" style="margin-top: 8px;" required>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 2rem; padding: 14px; font-size: 1rem; font-weight: 700; letter-spacing: 0.5px; border-radius: 6px;">Sign In</button>
    </form>
    
    <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem; color: var(--text-muted);">
        Don't have an account registry? <a href="/register" style="color: var(--primary); text-decoration: none; font-weight: 800; border-bottom: 2px solid var(--primary); padding-bottom: 2px; margin-left: 4px;">Register here</a>
    </p>
</div>

<% if (typeof errorMsg !== 'undefined' && errorMsg !== null) { %>
    <div id="loginErrorModal" style="display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(4px); z-index: 999999; justify-content: center; align-items: center;">
        <div class="card" style="max-width: 440px; width: 90%; text-align: center; padding: 2.5rem; border-radius: 14px; border: 1px solid var(--border); background-color: var(--card-bg); box-shadow: var(--shadow);">
            <div style="font-size: 3rem; margin-bottom: 1rem;">❌</div>
            <h3 style="margin-bottom: 0.75rem; color: var(--text-main); font-weight: 800; font-size: 1.4rem;">Authentication Failed</h3>
            <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; line-height: 1.55;"><%= errorMsg %></p>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <button onclick="document.getElementById('loginErrorModal').style.display='none'" class="btn" style="width: 100%; padding: 12px; font-weight: 700; background-color: var(--border); color: var(--text-main); border-radius: 6px;">Try Logging In Again</button>
                <a href="/register" class="btn btn-primary" style="text-decoration: none; text-align: center; padding: 12px; font-weight: 800; font-size: 1rem; border-radius: 6px; background-color: var(--primary);">Go to Register Account</a>
            </div>
        </div>
    </div>
<% } %>

<%- include('partials/footer') %>