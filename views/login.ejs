<%- include('partials/header') %>

<div class="card" style="max-width: 500px; margin: 4rem auto 2rem; box-shadow: var(--shadow); border: 1px solid var(--border);">
    
    <h1 style="text-align: center; margin-bottom: 2.5rem; color: var(--text-main); font-weight: 800; letter-spacing: -0.5px;">Account Sign In</h1>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; padding: 12px; border-radius: 6px; margin-bottom: 1.5rem; text-align: center; font-weight: 600;">
            <%= error %>
        </div>
    <% } %>

    <form action="/auth/login" method="POST">
        <div class="form-group">
            <label for="loginUsername" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Username</label>
            <input type="text" id="loginUsername" name="username" placeholder="Enter your username" style="margin-top: 8px;" required>
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem; position: relative;">
            <label for="loginPassword" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Password</label>
            <input type="password" id="loginPassword" name="password" placeholder="Enter secure password" style="margin-top: 8px; padding-right: 40px;" required>
            <span id="togglePassword" style="position: absolute; right: 12px; top: 42px; cursor: pointer;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </span>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 2rem; padding: 14px; font-weight: 700; border-radius: 6px;">Sign In</button>
    </form>
    
    <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem; color: var(--text-muted);">
        Don't have an account? <a href="/register" style="color: var(--primary); font-weight: 800; border-bottom: 2px solid var(--primary);">Register here</a>
    </p>
</div>

<script>
    const togglePassword = document.querySelector('#togglePassword');
    const password = document.querySelector('#loginPassword');
    togglePassword.addEventListener('click', () => {
        const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
        password.setAttribute('type', type);
    });
</script>

<%- include('partials/footer') %>