<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'HabitTracker' %></title>
    
    <link rel="stylesheet" href="/css/style.css">
    
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <div class="site-wrapper">
        
        <header class="navbar">
            <div class="logo">
                <a href="/" data-i18n="logo">Habitify</a>
            </div>
            
            <nav class="nav-links">
                <a href="/" data-i18n="nav_dashboard">Dashboard</a>
                <a href="/manage" data-i18n="nav_manage">Manage</a>
                <a href="/timer" data-i18n="nav_timer">Timer</a>
                <a href="/diary" data-i18n="nav_diary">Diary</a>
                
                <div class="profile-dropdown">
                    <button onclick="toggleProfileMenu(event)" class="btn-profile">
                        Profile ▼
                    </button>
                    <div id="profileMenu" class="dropdown-content">
                        <a href="/profile/details">Profile Details</a>
                        <a href="/profile/settings">Account Settings</a>
                        <hr style="border: 0; border-top: 1px solid var(--border); margin: 0;">
                        <a href="/auth/logout" style="color: var(--danger); font-weight: 600;">Sign Out</a>
                    </div>
                </div>
                
                <button id="themeToggle" class="btn-icon" style="margin-left: 15px;">🌙</button>
                <button id="langToggle" class="btn-icon" style="font-size: 0.9rem; font-weight: 600;">عربي</button>
            </nav>
        </header>

        <main class="container">