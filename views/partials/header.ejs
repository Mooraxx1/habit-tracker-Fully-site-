<!DOCTYPE html>
<% 
  let currentSystemLang = "en"; 
  let currentSystemDir = "ltr";
  if (typeof user !== 'undefined' && user && user.language) {
      currentSystemLang = user.language;
      currentSystemDir = user.language === 'ar' ? 'rtl' : 'ltr';
  }
%>
<html lang="<%= currentSystemLang %>" dir="<%= currentSystemDir %>" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'The Habiter' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* ==========================================================================
            GLOBAL RE-ENGINEERED NAVIGATION LAYER STYLES
           ========================================================================== */
        .nav-links {
            position: relative;
            display: flex;
            align-items: center;
        }

        .nav-item {
            position: relative;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 0.5rem 0.75rem;
            transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            user-select: none;
            display: inline-flex;
            align-items: center;
        }

        /* Hover and Permanent Route Highlight Sync */
        .nav-item:hover, .nav-item.active {
            color: var(--primary) !important;
        }

        /* Animated Sliding Underline Tracker */
        .nav-underline-indicator {
            position: absolute;
            bottom: -4px;
            left: 0;
            height: 2px;
            background-color: var(--primary);
            border-radius: 2px;
            transition: left 0.35s cubic-bezier(0.4, 0, 0.2, 1), width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
        }

        /* Smooth Dropdown Animation & Hitbox Bridging */
        .profile-dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: block;
            position: absolute;
            right: 0;
            top: 100%;
            background-color: var(--card-bg);
            min-width: 190px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
            border-radius: 8px;
            z-index: 99999;
            border: 1px solid var(--border);
            margin-top: 12px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
                        transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
                        visibility 0.25s linear;
            overflow: hidden;
        }

        /* Hitbox bridge prevents dropdown from closing during cursor transit */
        .dropdown-content::before {
            content: '';
            position: absolute;
            top: -15px;
            left: 0;
            width: 100%;
            height: 15px;
        }

        .profile-dropdown:hover .dropdown-content,
        .profile-dropdown.forced-open .dropdown-content {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-content a {
            display: block;
            padding: 12px 16px;
            text-decoration: none;
            color: var(--text-main);
            font-size: 0.95rem;
            font-weight: 500;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .dropdown-content a:hover {
            background-color: var(--bg-color);
            color: var(--primary);
        }

        /* Highlighted & Animated Tutorial Link Configurations */
        .dropdown-content a.tutorial-nav-link {
            color: var(--primary) !important;
            font-weight: 800 !important;
            letter-spacing: 0.2px;
            text-shadow: 0 0 1px rgba(0, 0, 0, 0.2);
            transition: text-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
                        background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                        letter-spacing 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .dropdown-content a.tutorial-nav-link:hover {
            background-color: var(--bg-color);
            letter-spacing: 0.4px;
            text-shadow: 0 0 8px var(--primary), 0 0 18px var(--primary);
        }

        /* Rounded Radio Switch Theme Slider Button */
        .theme-switch-container {
            display: flex;
            align-items: center;
            background-color: var(--border);
            width: 58px;
            height: 30px;
            border-radius: 20px;
            padding: 3px;
            cursor: pointer;
            position: relative;
            user-select: none;
            margin-left: 15px;
            transition: background-color 0.3s ease;
        }

        .theme-switch-nob {
            width: 24px;
            height: 24px;
            background-color: var(--card-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            left: 3px;
            font-size: 0.95rem;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.3s ease;
            box-shadow: 0 2px 5px rgba(0,0,0,0.25);
        }

        html[data-theme="light"] .theme-switch-nob {
            transform: translateX(28px);
        }

        /* Symmetric Twin Slider Language Framework Component */
        .lang-switch-container {
            display: flex;
            align-items: center;
            background-color: var(--border);
            width: 58px;
            height: 30px;
            border-radius: 20px;
            padding: 3px;
            cursor: pointer;
            position: relative;
            user-select: none;
            margin-left: 15px;
            transition: background-color 0.3s ease;
        }

        .lang-switch-nob {
            width: 24px;
            height: 24px;
            background-color: var(--card-bg);
            color: var(--primary);
            font-weight: 800;
            font-size: 0.72rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            left: 3px;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.3s ease, color 0.3s ease;
            box-shadow: 0 2px 5px rgba(0,0,0,0.25);
        }

        /* Directional Spacing Logic for Authentication App Bar Sliders */
        .nav-logout {
            margin-left: 20px;
            color: var(--danger);
            font-weight: 700;
            text-decoration: none;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
        }

        /* Language Transform Switch Constraints mapping */
        html[lang="ar"] .lang-switch-nob {
            transform: translateX(28px);
        }

        /* RTL Specific adjustments for standard header layouts */
        html[dir="rtl"] .dropdown-content {
            right: auto;
            left: 0;
        }
        html[dir="rtl"] .theme-switch-container,
        html[dir="rtl"] .lang-switch-container {
            margin-left: 0;
            margin-right: 15px;
        }
        html[dir="rtl"] .nav-logout {
            margin-left: 0;
            margin-right: 20px;
        }

        /* Authentication Layout Classes */
        .navbar.auth-navbar {
            justify-content: center;
            position: relative;
        }

        .navbar.auth-navbar .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }

        .navbar.auth-navbar .auth-right-container {
            margin-left: auto;
            display: flex;
            align-items: center;
            z-index: 10;
        }
        html[dir="rtl"] .navbar.auth-navbar .auth-right-container {
            margin-left: 0;
            margin-right: auto;
        }
    </style>
</head>
<body>
    <script>
        (function() {
            const savedTheme = localStorage.getItem("theme") || "dark";
            document.documentElement.setAttribute("data-theme", savedTheme);
            const savedLang = localStorage.getItem("language") || "en";
            document.documentElement.setAttribute("lang", savedLang);
            document.documentElement.setAttribute("dir", savedLang === "ar" ? "rtl" : "ltr");
        })();
    </script>

    <div class="site-wrapper">
        <% 
            let isAuthPage = false;
            if (typeof title !== 'undefined' && (title === 'Login' || title === 'Register')) {
                isAuthPage = true;
            }
        %>
        <nav class="navbar <%= isAuthPage ? 'auth-navbar' : '' %>">
            <div class="logo">
                <a href="/" data-i18n="app_brand_logo_title">The Habiter</a>
            </div>

            <% if (!isAuthPage) { %>
                <div class="nav-links" id="mainNavLinks">
                    <a href="/" class="nav-item" data-i18n="nav_dashboard">Dashboard</a>
                    <a href="/manage" class="nav-item" data-i18n="nav_manage">Manage</a>
                    <a href="/timer" class="nav-item" data-i18n="nav_timer">Timer</a>
                    <a href="/diary" class="nav-item" data-i18n="nav_diary">Diary</a>
                    
                    <div class="profile-dropdown" id="profileDropdownTab">
                        <span class="nav-item" id="profileTabAnchor"><span data-i18n="nav_settings">Settings</span> ▼</span>
                        <div class="dropdown-content">
                            <a href="/settings/profile" data-i18n="drop_profile">My Profile</a>
                            <a href="/settings/account" data-i18n="drop_account">Account Settings</a>
                            <a href="/settings/tutorial" class="tutorial-nav-link" data-i18n="drop_tutorial">App Tutorial</a>
                        </div>
                    </div>

                    <div class="nav-underline-indicator" id="navIndicator"></div>
                    
                    <div class="theme-switch-container" id="themeToggleSlider" title="Toggle Display Color Mode">
                        <div class="theme-switch-nob" id="themeEmojiNob">🌙</div>
                    </div>

                    <div class="lang-switch-container" id="languageToggleSlider" title="Toggle Localization Language Switch">
                        <div class="lang-switch-nob" id="langTextNob">EN</div>
                    </div>
                    
                    <a href="/auth/logout" class="nav-logout" data-i18n="nav_logout">Logout</a>
                </div>
            <% } else { %>
                <div class="auth-right-container">
                    <div class="theme-switch-container" id="themeToggleSlider" title="Toggle Display Color Mode">
                        <div class="theme-switch-nob" id="themeEmojiNob">🌙</div>
                    </div>
                    <div class="lang-switch-container" id="languageToggleSlider" title="Toggle Localization Language Switch">
                        <div class="lang-switch-nob" id="langTextNob">EN</div>
                    </div>
                </div>
            <% } %>
        </nav>
        <main class="container">

<script>
document.addEventListener("DOMContentLoaded", () => {
    const navLinksContainer = document.getElementById("mainNavLinks");
    const indicator = document.getElementById("navIndicator");
    const items = document.querySelectorAll(".nav-item");
    const profileDropdownTab = document.getElementById("profileDropdownTab");
    const profileTabAnchor = document.getElementById("profileTabAnchor");

    if (navLinksContainer && indicator) {
        function moveIndicator(element) {
            if (!element || !indicator) return;
            const containerRect = navLinksContainer.getBoundingClientRect();
            const elementRect = element.getBoundingClientRect();
            
            let leftOffset = elementRect.left - containerRect.left;
            
            indicator.style.left = `${leftOffset}px`;
            indicator.style.width = `${elementRect.width}px`;
        }

        const currentPath = window.location.pathname;
        let fallbackActive = items[0];

        items.forEach(item => {
            const hrefAttr = item.getAttribute("href");
            
            if (hrefAttr && hrefAttr === currentPath) {
                item.classList.add("active");
                fallbackActive = item;
            } else if (!hrefAttr && (currentPath.includes("/settings/profile") || currentPath.includes("/settings/account") || currentPath.includes("/settings/tutorial"))) {
                profileTabAnchor.classList.add("active");
                fallbackActive = profileTabAnchor;
            }

            item.addEventListener("mouseenter", (e) => moveIndicator(e.target));
        });

        navLinksContainer.addEventListener("mouseleave", () => moveIndicator(fallbackActive));
        setTimeout(() => { moveIndicator(fallbackActive); }, 100);
        window.addEventListener("resize", () => moveIndicator(fallbackActive));
    }

    if (profileDropdownTab) {
        profileDropdownTab.addEventListener("click", (e) => {
            e.stopPropagation();
            profileDropdownTab.classList.toggle("forced-open");
        });

        document.addEventListener("click", () => {
            profileDropdownTab.classList.remove("forced-open");
        });
    }

    // Theme Engine Hook
    const themeToggleSlider = document.getElementById("themeToggleSlider");
    const themeEmojiNob = document.getElementById("themeEmojiNob");
    const htmlElement = document.documentElement;

    function applyEmojiState(theme) {
        if (!themeEmojiNob) return;
        themeEmojiNob.textContent = theme === "light" ? "☀️" : "🌙";
    }

    const structuralTheme = htmlElement.getAttribute("data-theme") || "dark";
    applyEmojiState(structuralTheme);

    if (themeToggleSlider) {
        themeToggleSlider.addEventListener("click", () => {
            const activeState = htmlElement.getAttribute("data-theme");
            const targetTheme = activeState === "dark" ? "light" : "dark";
            
            htmlElement.setAttribute("data-theme", targetTheme);
            localStorage.setItem("theme", targetTheme);
            applyEmojiState(targetTheme);
        });
    }

    // Language Engine Interconnected Asymmetric Network Framework Sync Loop
    const languageToggleSlider = document.getElementById("languageToggleSlider");
    const langTextNob = document.getElementById("langTextNob");

    function applyLangTextState(lang) {
        if (!langTextNob) return;
        langTextNob.textContent = lang === "ar" ? "AR" : "EN";
    }

    const structuralLang = htmlElement.getAttribute("lang") || "en";
    applyLangTextState(structuralLang);

    if (languageToggleSlider) {
        languageToggleSlider.addEventListener("click", () => {
            const activeLang = htmlElement.getAttribute("lang") || "en";
            const targetLang = activeLang === "en" ? "ar" : "en";
            
            htmlElement.setAttribute("lang", targetLang);
            htmlElement.setAttribute("dir", targetLang === "ar" ? "rtl" : "ltr");
            localStorage.setItem("language", targetLang);
            applyLangTextState(targetLang);

            fetch("/api/profile/language", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ language: targetLang })
            })
            .then(() => {
                if (typeof window.retranslatePageScope === "function") {
                    window.retranslatePageScope(targetLang);
                } else {
                    window.location.reload();
                }
            })
            .catch(err => {
                console.warn("[Language Sync Sync Error]:", err.message);
                window.location.reload();
            });
        });
    }
});
</script>