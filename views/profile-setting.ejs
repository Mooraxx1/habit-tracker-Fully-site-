<%- include('partials/header') %>

<div style="margin-bottom: 2rem; text-align: center;">
    <h1 style="font-size: 2rem; font-weight: 700; color: var(--text-main);" data-i18n="account_settings_title">Account Profile Settings</h1>
    <p style="color: var(--text-muted); margin-top: 4px;" data-i18n="account_settings_desc">Personalize your dashboard presence profile metrics</p>
</div>

<div style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 2.5rem; max-width: 650px; margin: 0 auto; box-shadow: var(--shadow);">
    <form action="/api/profile/update" method="POST">
        
        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--text-main);" data-i18n="label_display_name">Display Profile Name</label>
            <input type="text" name="displayName" value="<%= (typeof user !== 'undefined' && user && user.displayName) ? user.displayName : '' %>" style="width: 100%; padding: 10px 14px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-color); color: var(--text-main); font-size: 1rem; font-family: inherit;" placeholder="Enter custom profile display identity name" data-i18n="placeholder_display_name">
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--text-main);" data-i18n="label_bio">Personal Status Bio</label>
            <textarea name="bio" style="width: 100%; height: 120px; padding: 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-color); color: var(--text-main); font-size: 1rem; font-family: inherit; resize: vertical;" placeholder="Tell us about your optimization goals, routines, or target milestones..." data-i18n="placeholder_bio"><%= (typeof user !== 'undefined' && user && user.bio) ? user.bio : '' %></textarea>
        </div>

        <div style="margin-bottom: 2rem;">
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--text-main);" data-i18n="label_avatar_url">Profile Picture Avatar Link</label>
            <input type="text" name="avatarUrl" value="<%= (typeof user !== 'undefined' && user && user.avatarUrl) ? user.avatarUrl : '' %>" style="width: 100%; padding: 10px 14px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-color); color: var(--text-main); font-size: 1rem; font-family: inherit;" placeholder="Paste a public web reference image URL address path" data-i18n="placeholder_avatar_url">
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 14px; font-size: 1rem; font-weight: 700; border-radius: 6px; cursor: pointer; border: none; letter-spacing: 0.5px;" data-i18n="btn_save_changes">
            Save Changes
        </button>
    </form>
</div>

<%- include('partials/footer') %>