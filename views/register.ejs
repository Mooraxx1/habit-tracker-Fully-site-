<%- include('partials/header') %>

<div class="card" style="max-width: 500px; margin: 4rem auto 2rem; box-shadow: var(--shadow); border: 1px solid var(--border); background-color: var(--card-bg); padding: 1.5rem; border-radius: 12px;">
    
    <% if (typeof successUser !== 'undefined' && successUser) { %>
        <div style="text-align: center; padding: 1rem 0;">
            <div style="width: 64px; height: 64px; background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 50%; margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold; box-shadow: var(--shadow);">
                ✓
            </div>
            <h1 style="color: var(--text-main); font-weight: 800; font-size: 1.75rem; margin-bottom: 0.5rem;">Registration Complete!</h1>
            <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.5; margin-bottom: 2rem;">
                Congratulations! You have successfully registered your credentials as <strong style="color: var(--primary);">@<%= successUser %></strong>.
            </p>
            <a href="/login" class="btn btn-primary" style="display: block; text-decoration: none; text-align: center; padding: 14px; font-weight: 700; border-radius: 6px; cursor: pointer;">
                Proceed to Log In
            </a>
        </div>
    <% } else { %>
    
        <h1 style="text-align: center; margin-bottom: 2.5rem; color: var(--text-main); font-weight: 800; letter-spacing: -0.5px;">Create an Account</h1>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; padding: 12px; border-radius: 6px; margin-bottom: 1.5rem; text-align: center; font-weight: 600;">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/register" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="regUsername" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Username</label>
                <input type="text" id="regUsername" name="username" placeholder="Choose a unique username" style="margin-top: 8px; width: 100%; padding: 10px; background-color: var(--bg-color); color: var(--text-main); border: 1px solid var(--border); border-radius: 6px; font-family: inherit;" required>
            </div>
            
            <div class="form-group" style="margin-top: 1.5rem; margin-bottom: 1rem;">
                <label for="regPassword" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Password</label>
                <div style="position: relative; display: flex; align-items: center; margin-top: 8px;">
                    <input type="password" id="regPassword" name="password" placeholder="Create a secure password" style="width: 100%; margin: 0; padding-right: 42px; background-color: var(--bg-color); color: var(--text-main); border: 1px solid var(--border); padding: 10px; border-radius: 6px; font-family: inherit;" required>
                    <span id="toggleRegPassword" style="position: absolute; right: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </span>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 2rem; padding: 14px; font-size: 1rem; font-weight: 700; letter-spacing: 0.5px; border-radius: 6px; cursor: pointer;">Sign Up</button>
        </form>
        
        <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem; color: var(--text-muted);">
            Already have an account? <a href="/login" style="color: var(--primary); text-decoration: none; font-weight: 800; border-bottom: 2px solid var(--primary); padding-bottom: 2px; margin-left: 4px;">Login here</a>
        </p>
    <% } %>
</div>

<%- include('partials/footer') %>