<%- include('partials/header') %>

<style>
    /* Dynamic adjustments for Arabic RTL Layout */
    html[lang="ar"] .password-field-input {
        padding: 12px !important;
        padding-left: 42px !important;
        direction: rtl;
    }
    html[lang="ar"] .password-toggle-btn {
        left: 14px !important;
        right: auto !important;
    }
</style>

<div class="card" style="max-width: 500px; margin: 4rem auto 2rem; box-shadow: var(--shadow); border: 1px solid var(--border); background-color: var(--card-bg); padding: 2rem; border-radius: 12px;">
    
    <% if (typeof successUser !== 'undefined' && successUser) { %>
        <div style="text-align: center; padding: 1rem 0;">
            <div style="width: 64px; height: 64px; background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 50%; margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold; box-shadow: var(--shadow);">
                ✓
            </div>
            <h1 style="color: var(--text-main); font-weight: 800; font-size: 1.75rem; margin-bottom: 0.5rem;" data-i18n="reg_complete_heading">Registration Complete!</h1>
            <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.5; margin-bottom: 2rem;">
                <span data-i18n="reg_success_msg">Congratulations! You have successfully registered your credentials as</span> <strong style="color: var(--primary);">@<%= successUser %></strong>.
            </p>
            <a href="/login" class="btn btn-primary" style="display: block; text-decoration: none; text-align: center; padding: 14px; font-weight: 700; border-radius: 8px; cursor: pointer; border: none;" data-i18n="btn_proceed_login">
                Proceed to Log In
            </a>
        </div>
    <% } else { %>
    
        <h1 style="text-align: center; margin-bottom: 2.5rem; color: var(--text-main); font-weight: 800; letter-spacing: -0.5px;" data-i18n="reg_heading">Create an Account</h1>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; padding: 12px; border-radius: 6px; margin-bottom: 1.5rem; text-align: center; font-weight: 600;">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/register" method="POST">
            <div class="form-group" style="margin-bottom: 1.25rem;">
                <label for="regUsername" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);" data-i18n="field_username">Username</label>
                <input type="text" id="regUsername" name="username" placeholder="Choose a unique username" data-i18n="placeholder_reg_username" style="margin-top: 8px; width: 100%; padding: 12px; background-color: var(--bg-color); color: var(--text-main); border: 1px solid var(--border); border-radius: 8px; font-family: inherit; font-size: 0.95rem;" required>
            </div>
            
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="regPassword" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);" data-i18n="field_password">Password</label>
                <div style="position: relative; display: flex; align-items: center; margin-top: 8px;">
                    <input type="password" id="regPassword" name="password" placeholder="Create a secure password" data-i18n="placeholder_reg_password" class="password-field-input" style="width: 100%; margin: 0; padding: 12px; padding-right: 42px; background-color: var(--bg-color); color: var(--text-main); border: 1px solid var(--border); border-radius: 8px; font-family: inherit; font-size: 0.95rem;" required>
                    <span id="toggleRegPassword" class="password-toggle-btn" style="position: absolute; right: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" style="transition: stroke 0.2s ease;">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </span>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 2rem; padding: 14px; font-size: 1rem; font-weight: 700; letter-spacing: 0.5px; border-radius: 8px; cursor: pointer; border: none;" data-i18n="btn_signup">Sign Up</button>
        </form>
        
        <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem; color: var(--text-muted);">
            <span data-i18n="reg_has_account">Already have an account?</span> 
            <a href="/login" style="color: var(--primary); text-decoration: none; font-weight: 800; border-bottom: 2px solid var(--primary); padding-bottom: 2px; margin-left: 4px;" data-i18n="link_login_here">Login here</a>
        </p>
    <% } %>
</div>

<script>
const toggleBtn = document.getElementById('toggleRegPassword');
if (toggleBtn) {
    toggleBtn.addEventListener('click', function() {
        const pwd = document.getElementById('regPassword');
        const type = pwd.getAttribute('type') === 'password' ? 'text' : 'password';
        pwd.setAttribute('type', type);
    });
}
</script>

<%- include('partials/footer') %>