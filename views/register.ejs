<%- include('partials/header') %>

<div class="card" style="max-width: 500px; margin: 4rem auto 2rem; box-shadow: var(--shadow); border: 1px solid var(--border);">
    
    <h1 style="text-align: center; margin-bottom: 2.5rem; color: var(--text-main); font-weight: 800; letter-spacing: -0.5px;" data-i18n="register_title">Create an Account</h1>
    
    <form action="/auth/register" method="POST">
        <div class="form-group">
            <label for="regUsername" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Username</label>
            <input type="text" id="regUsername" name="username" placeholder="Choose a unique username" style="margin-top: 8px;" required>
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem;">
            <label for="regPassword" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);">Password</label>
            <input type="password" id="regPassword" name="password" placeholder="Create a secure password" style="margin-top: 8px;" required>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 2rem; padding: 14px; font-size: 1rem; font-weight: 700; letter-spacing: 0.5px; border-radius: 6px;">Sign Up</button>
    </form>
    
    <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem; color: var(--text-muted);">
        Already have an account? <a href="/login" style="color: var(--primary); text-decoration: none; font-weight: 800; border-bottom: 2px solid var(--primary); padding-bottom: 2px; margin-left: 4px;">Login here</a>
    </p>
</div>

<% if (typeof successUser !== 'undefined' && successUser !== null) { %>
    <div id="successRegModal" style="display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(4px); z-index: 999999; justify-content: center; align-items: center;">
        <div class="card" style="max-width: 440px; width: 90%; text-align: center; padding: 2.5rem; border-radius: 14px; border: 1px solid var(--border); background-color: var(--card-bg); box-shadow: var(--shadow);">
            <div style="font-size: 3rem; margin-bottom: 1rem; color: #10b981;">🎉</div>
            <h3 style="margin-bottom: 0.75rem; color: var(--text-main); font-weight: 800; font-size: 1.4rem;">Registration Successful!</h3>
            <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; line-height: 1.5;">Congrats! You are officially registered as <strong style="color: var(--primary); font-weight: 700;">@<%= successUser %></strong>. Your account mapping container is now live.</p>
            <a href="/login" class="btn btn-primary" style="display: block; text-decoration: none; text-align: center; padding: 12px; font-weight: 700; font-size: 1rem; border-radius: 6px;">Proceed to Login</a>
        </div>
    </div>
<% } %>

<% if (typeof errorMsg !== 'undefined' && errorMsg !== null) { %>
    <div id="errorRegModal" style="display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(4px); z-index: 999999; justify-content: center; align-items: center;">
        <div class="card" style="max-width: 440px; width: 90%; text-align: center; padding: 2.5rem; border-radius: 14px; border: 1px solid var(--danger); background-color: var(--card-bg); box-shadow: var(--shadow);">
            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--danger);">⚠️</div>
            <h3 style="margin-bottom: 0.75rem; color: var(--text-main); font-weight: 800; font-size: 1.4rem;">Registration Halt!</h3>
            <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; line-height: 1.5;"><%= errorMsg %></p>
            <button onclick="document.getElementById('errorRegModal').style.display='none'" class="btn btn-danger" style="width: 100%; padding: 12px; font-weight: 700; font-size: 1rem; border-radius: 6px;">Dismiss and Retry</button>
        </div>
    </div>
<% } %>

<%- include('partials/footer') %>