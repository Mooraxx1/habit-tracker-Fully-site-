<%- include('partials/header') %>

<div class="page-header">
    <h1 data-i18n="manage_title">Manage Habits</h1>
</div>

<div class="card">
    <form class="habit-form" action="/api/habits" method="POST">
        
        <div class="form-group">
            <label for="habitNameField" style="font-weight: 600; font-size: 0.95rem; color: var(--text-main);">Habit Name</label>
            <input type="text" id="habitNameField" name="name" placeholder="e.g. Fullstack Bootcamp Dr Angela Yu" required>
        </div>
        
        <div class="form-group" style="margin-top: 1.25rem;">
            <label for="habitTimeField" style="font-weight: 600; font-size: 0.95rem; color: var(--text-main);">Required Time daily (HH:MM)</label>
            <input type="text" id="habitTimeField" name="requiredTimeFormat" placeholder="03:30" pattern="^(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]$" title="Format must match HH:MM structure specifications" style="font-family: monospace;" required>
        </div>
        
        <div class="form-group" style="margin-top: 1.25rem;">
            <label for="habitScheduleField" style="font-weight: 600; font-size: 0.95rem; color: var(--text-main);">Starting Date (Optional)</label>
            <input type="datetime-local" id="habitScheduleField" name="schedule" style="cursor: pointer;" onclick="try { this.showPicker(); } catch(e) {}">
        </div>

        <div class="form-group" style="margin-top: 1.25rem;">
            <label style="font-weight: 600; font-size: 0.95rem; color: var(--text-main);">Reference Source URLs (Optional)</label>
            <div id="urlFieldsContainerWrapper">
                <div style="display: flex; gap: 10px; margin-bottom: 8px;">
                    <input type="url" name="urls" placeholder="e.g. https://www.udemy.com/course/the-complete-web-development-bootcamp/">
                    <button type="button" class="btn btn-primary" onclick="appendNewUrlFieldRow()" style="padding: 0 16px; font-size: 1.25rem; border-radius: 6px;">+</button>
                </div>
            </div>
        </div>
        
        <button type="submit" class="btn btn-primary" data-i18n="add_habit" style="width: 100%; margin-top: 1.5rem; padding: 12px; font-size: 1rem;">Add Habit</button>
    </form>
</div>

<div class="manage-habits-list" id="habitsListCardContainer" data-habits='<%= JSON.stringify(habits || []) %>'>
    <h3 style="margin-bottom: 1.5rem; color: var(--text-main);">Existing Habits Registry</h3>
    
    <% if (typeof habits !== 'undefined' && habits.length > 0) { %>
        <% habits.forEach(habit => { %>
            <div class="habit-management-card" id="card-<%= habit.id %>">
                <div class="habit-info-block">
                    <h4 id="name-display-<%= habit.id %>"><%= habit.name %></h4>
                    <p>Daily Requirement Target: <strong style="color: var(--primary);"><%= habit.requiredTime %> hrs</strong></p>
                    <% if (habit.urls && habit.urls.length > 0) { %>
                        <div style="margin-top: 6px; display: flex; flex-wrap: wrap; gap: 8px;">
                            <% habit.urls.forEach((url, index) => { %>
                                <a href="<%= url %>" target="_blank" style="font-size: 0.8rem; color: var(--primary); text-decoration: underline;">URL Link #<%= index + 1 %></a>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
                
                <div class="habit-controls-block">
                    <button class="btn btn-inline-edit" onclick="triggerInlineEdit('<%= habit.id %>', '<%= habit.name %>', '<%= habit.requiredTime %>')">Edit</button>
                    <button class="btn btn-danger" style="padding: 6px 12px; font-size: 0.85rem;" onclick="triggerInlineDelete('<%= habit.id %>')">Remove</button>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p style="color: var(--text-muted); font-style: italic;">No routines initialized yet. Register one above to manage tracking operations.</p>
    <% } %>
</div>

<div id="successHabitModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(4px); z-index: 999999; justify-content: center; align-items: center;">
    <div class="card" style="max-width: 440px; width: 90%; text-align: center; padding: 2.5rem; border-radius: 14px; border: 1px solid var(--border); background-color: var(--card-bg); box-shadow: var(--shadow);">
        <div style="font-size: 3rem; margin-bottom: 1rem; color: #10b981;">✨</div>
        <h3 style="margin-bottom: 0.75rem; color: var(--text-main); font-weight: 800; font-size: 1.4rem;">Habit Created!</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; line-height: 1.5;">Your new routine has been securely saved and initialized inside your dashboard ledger maps.</p>
        <button onclick="cleanModalURLRedirect()" class="btn btn-primary" style="width: 100%; padding: 12px; font-weight: 700; font-size: 1rem; border-radius: 6px;">Close</button>
    </div>
</div>

<script>
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('created') === 'success') {
    const modal = document.getElementById("successHabitModal");
    if (modal) modal.style.display = "flex";
}

function cleanModalURLRedirect() {
    document.getElementById('successHabitModal').remove();
    window.location.href = "/manage"; 
}

const durationInputField = document.getElementById("habitTimeField");
if (durationInputField) {
    durationInputField.addEventListener("input", function(e) {
        let numericValue = e.target.value.replace(/\D/g, ""); 
        if (numericValue.length > 4) numericValue = numericValue.substring(0, 4);
        if (numericValue.length > 2) {
            e.target.value = numericValue.substring(0, 2) + ":" + numericValue.substring(2);
        } else {
            e.target.value = numericValue;
        }
    });
}

// NEW ENGINE: Spawns incremental URL parameters slots natively with removal triggers
function appendNewUrlFieldRow() {
    const wrapper = document.getElementById("urlFieldsContainerWrapper");
    const dynamicRow = document.createElement("div");
    dynamicRow.style = "display: flex; gap: 10px; margin-bottom: 8px;";
    dynamicRow.innerHTML = `
        <input type="url" name="urls" placeholder="Additional source reference anchor URL link">
        <button type="button" class="btn" onclick="this.parentElement.remove()" style="padding: 0 16px; background-color: var(--danger); color: white; border-radius: 6px;">✕</button>
    `;
    wrapper.appendChild(dynamicRow);
}

function triggerInlineEdit(id, currentName, currentTime) {
    const newName = prompt("Edit Habit Name:", currentName);
    if (newName === null || newName.trim() === "") return;
    
    const newTime = prompt("Edit Required Time daily (Hours decimal style):", currentTime);
    if (newTime === null || isNaN(parseFloat(newTime)) || parseFloat(newTime) <= 0) return;

    fetch("/api/habits/update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: id, name: newName.trim(), requiredTime: parseFloat(newTime) })
    })
    .then(res => res.json())
    .then(data => { if (data.success) window.location.reload(); })
    .catch(err => console.error(err));
}

function triggerInlineDelete(id) {
    if (!confirm("Are you sure you want to completely remove this habit?")) return;
    fetch("/api/habits/delete", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: id })
    })
    .then(res => res.json())
    .then(data => { if (data.success) window.location.reload(); })
    .catch(err => console.error(err));
}
</script>

<%- include('partials/footer') %>