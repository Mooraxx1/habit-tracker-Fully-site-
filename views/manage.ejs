<%- include('partials/header') %>

<div class="page-header" style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.25rem; font-weight: 800; color: var(--text-main); letter-spacing: -0.5px;" data-i18n="manage_title">Manage Habits</h1>
</div>

<div class="card" style="background-color: var(--card-bg); border: 1px solid var(--border); padding: 2rem; border-radius: 12px; box-shadow: var(--shadow);">
    <form class="habit-form" action="/api/habits" method="POST">
        
        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="habitNameField" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main); display: block; margin-bottom: 8px;" data-i18n="field_habit_name">Habit Name</label>
            <input type="text" id="habitNameField" name="name" placeholder="e.g. Write Your Habits Name" data-i18n="placeholder_habit_name" required>
        </div>
        
        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="habitTimeField" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main); display: block; margin-bottom: 8px;" data-i18n="field_required_time">Required Time daily (HH:MM)</label>
            <input type="text" id="habitTimeField" name="requiredTimeFormat" placeholder="HH:MM" pattern="^(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]$" title="Format must match HH:MM structure specifications" data-i18n="[title]title_time_format" style="font-family: monospace;" required>
        </div>
        
        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="habitScheduleField" style="font-weight: 700; font-size: 0.95rem; color: var(--text-main); display: block; margin-bottom: 8px;" data-i18n="field_start_date">Starting Date (Optional)</label>
            <input type="datetime-local" id="habitScheduleField" name="schedule" style="cursor: pointer;" onclick="try { this.showPicker(); } catch(e) {}">
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label style="font-weight: 700; font-size: 0.95rem; color: var(--text-main); display: block; margin-bottom: 8px;" data-i18n="field_ref_urls">Reference Source URLs (Optional)</label>
            <div id="urlFieldsContainerWrapper">
                <div class="source-url-row">
                    <input type="text" name="sourceNames" placeholder="e.g. College Web" data-i18n="placeholder_source_name" style="flex: 1;">
                    <input type="url" name="urls" placeholder="e.g. https://example.com" data-i18n="placeholder_source_url" style="flex: 2;">
                    <button type="button" class="btn btn-primary btn-square-append" onclick="appendNewUrlFieldRow()">+</button>
                </div>
            </div>
        </div>
        
        <button type="submit" class="btn btn-primary" data-i18n="add_habit" style="width: 100%; margin-top: 1rem; padding: 14px; font-size: 1rem; font-weight: 700; border-radius: 8px; cursor: pointer; border: none; letter-spacing: 0.3px;">Add Habit</button>
    </form>
</div>

<div class="manage-habits-list" id="habitsListCardContainer" data-habits='<%= JSON.stringify(habits || []) %>' style="margin-top: 3.5rem;">
    <h3 style="margin-bottom: 1.5rem; color: var(--text-main); font-weight: 800; font-size: 1.35rem; letter-spacing: -0.3px;" data-i18n="existing_habits_title">Existing Habits Registry</h3>
    
    <% if (typeof habits !== 'undefined' && habits && habits.length > 0) { %>
        <% habits.forEach(habit => { %>
            <div class="habit-management-card" id="card-<%= habit.id %>" style="display: flex; justify-content: space-between; align-items: center; background-color: var(--card-bg); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 1rem; box-shadow: var(--shadow); transition: transform 0.2s ease;">
                <div class="habit-info-block">
                    <h4 id="name-display-<%= habit.id %>" style="font-size: 1.25rem; color: var(--text-main); font-weight: 700; margin: 0 0 0.5rem 0;"><%= habit.name %></h4>
                    <p style="color: var(--text-muted); font-size: 0.95rem; margin: 0;"><span data-i18n="daily_requirement_target">Daily Requirement Target:</span> <strong style="color: var(--primary); font-weight: 700;"><%= habit.requiredTime %> <span data-i18n="unit_hours">hrs</span></strong></p>
                    
                    <% if (habit.urls && habit.urls.length > 0) { %>
                        <div style="margin-top: 10px; display: flex; flex-wrap: wrap; gap: 8px;">
                            <% habit.urls.forEach((url, index) => { %>
                                <a href="<%= url %>" target="_blank" style="font-size: 0.85rem; color: var(--primary); text-decoration: none; font-weight: 600; border-bottom: 1px dashed var(--primary); padding-bottom: 1px;">
                                    <%= (habit.sourceNames && habit.sourceNames[index]) ? habit.sourceNames[index] : `Link #${index + 1}` %>
                                </a>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
                
                <div class="habit-controls-block" style="display: flex; gap: 0.75rem;">
                    <button type="button" class="btn btn-inline-edit" style="padding: 8px 16px; font-size: 0.85rem; font-weight: 700; border-radius: 6px; cursor: pointer; border: none;" onclick="openEditModal('<%= habit.id %>', '<%= habit.name %>', '<%= habit.requiredTime %>')" data-i18n="btn_edit">Edit</button>
                    <button type="button" class="btn" style="padding: 8px 16px; font-size: 0.85rem; font-weight: 700; background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 6px; cursor: pointer;" onclick="triggerDeleteConfirmation('<%= habit.id %>', '<%= habit.name %>')" data-i18n="btn_remove">Remove</button>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 3rem 0; font-size: 0.95rem;" data-i18n="no_routines_msg">No routines initialized yet. Register one above to manage tracking operations.</p>
    <% } %>
</div>

<div id="editHabitModal" class="custom-modal-backdrop">
    <div class="card custom-modal-card">
        <h3 style="font-size: 1.3rem; margin-bottom: 1.25rem; color: var(--text-main); font-weight: 800;" data-i18n="modify_habit_title">Modify Habit Configuration</h3>
        <input type="hidden" id="editModalHabitId">
        
        <div class="form-group" style="text-align: left; margin-bottom: 1.25rem;">
            <label style="font-weight: 700; font-size: 0.9rem; margin-bottom: 6px; display: block; color: var(--text-main);" data-i18n="field_habit_target_title">Habit Target Title</label>
            <input type="text" id="editModalHabitName" placeholder="Update title descriptor string" data-i18n="placeholder_update_title">
        </div>

        <div class="form-group" style="text-align: left; margin-bottom: 1.75rem;">
            <label style="font-weight: 700; font-size: 0.9rem; margin-bottom: 6px; display: block; color: var(--text-main);" data-i18n="field_daily_commitment">Daily Commitment Allocation (Decimal Hours)</label>
            <input type="number" id="editModalHabitTime" step="0.1" min="0.1" max="24" placeholder="e.g. 1.5">
        </div>

        <div style="display: flex; gap: 1rem;">
            <button type="button" class="btn" style="background: var(--border); color: var(--text-main); width: 100%;" onclick="closeEditModal()" data-i18n="btn_cancel">Cancel</button>
            <button type="button" class="btn btn-primary" style="width: 100%;" onclick="submitEditModalForm()" data-i18n="btn_save_changes">Save Changes</button>
        </div>
    </div>
</div>

<div id="deleteConfirmationModal" class="custom-modal-backdrop">
    <div class="card custom-modal-card" style="max-width: 420px; text-align: center;">
        <div style="width: 56px; height: 56px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 50%; margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold;">!</div>
        <h3 style="font-size: 1.3rem; margin-bottom: 0.5rem; color: var(--text-main); font-weight: 700;" data-i18n="remove_routine_title">Remove Routine?</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5; margin-bottom: 2rem;">
            <span data-i18n="remove_routine_confirm_pre">Are you sure you want to delete</span> <span id="deleteTargetHabitName" style="color: var(--primary); font-weight: 700;"></span><span data-i18n="remove_routine_confirm_post">? This historical analytics logging tracking cannot be undone.</span>
        </p>
        <div style="display: flex; gap: 1rem;">
            <button type="button" class="btn" style="background: var(--border); color: var(--text-main); width: 100%;" onclick="closeDeleteModal()" data-i18n="btn_cancel">Cancel</button>
            <button id="confirmDeleteButton" type="button" class="btn" style="background: #ef4444; color: #ffffff; width: 100%;" data-i18n="btn_confirm_delete">Confirm Delete</button>
        </div>
    </div>
</div>

<div id="successHabitModal" class="custom-modal-backdrop">
    <div class="card custom-modal-card" style="max-width: 440px; text-align: center; padding: 2.5rem;">
        <div style="font-size: 3.5rem; margin-bottom: 1rem; color: #10b981;">✨</div>
        <h3 style="margin-bottom: 0.75rem; color: var(--text-main); font-weight: 800; font-size: 1.4rem;" data-i18n="habit_created_title">Habit Created!</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; line-height: 1.5;" data-i18n="habit_created_desc">Your new routine has been securely saved and initialized inside your dashboard ledger maps.</p>
        <button type="button" onclick="cleanModalURLRedirect()" class="btn btn-primary" style="width: 100%;" data-i18n="btn_close">Close</button>
    </div>
</div>

<script>
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('created') === 'success') {
    const modal = document.getElementById("successHabitModal");
    if (modal) modal.style.display = "flex";
}

function cleanModalURLRedirect() {
    window.location.href = "/manage"; 
}

const durationInputField = document.getElementById("habitTimeField");
if (durationInputField) {
    durationInputField.addEventListener("input", function(e) {
        let numericValue = e.target.value.replace(/\D/g, ""); 
        if (numericValue.length > 4) numericValue = numericValue.substring(0, 4);
        if (numericValue.length > 2) {
            e.target.value = numericValue.substring(0, 2) + ":" + numericValue.substring(2);
        } else {
            e.target.value = numericValue;
        }
    });
}

function appendNewUrlFieldRow() {
    const wrapper = document.getElementById("urlFieldsContainerWrapper");
    const dynamicRow = document.createElement("div");
    dynamicRow.classList.add("source-url-row");
    dynamicRow.style.marginTop = "8px";
    
    const activeLang = document.documentElement.getAttribute("lang") || "en";
    const srcPlaceholder = activeLang === "ar" ? "ملصق وصفي للمصدر (مثال: ويكيبيديا)" : "Source descriptive label (e.g. Wiki)";

    dynamicRow.innerHTML = `
        <input type="text" name="sourceNames" placeholder="${srcPlaceholder}" style="flex: 1;">
        <input type="url" name="urls" placeholder="https://example.com" style="flex: 2;">
        <button type="button" class="btn btn-square-append" onclick="this.parentElement.remove()" style="background-color: var(--danger); color: white;">✕</button>
    `;
    wrapper.appendChild(dynamicRow);
}

function openEditModal(id, name, time) {
    document.getElementById("editModalHabitId").value = id;
    document.getElementById("editModalHabitName").value = name;
    document.getElementById("editModalHabitTime").value = time;
    document.getElementById("editHabitModal").style.display = "flex";
}

function closeEditModal() {
    document.getElementById("editHabitModal").style.display = "none";
}

function submitEditModalForm() {
    const id = document.getElementById("editModalHabitId").value;
    const name = document.getElementById("editModalHabitName").value.trim();
    const time = document.getElementById("editModalHabitTime").value;

    if (!name || !time || parseFloat(time) <= 0) return;

    fetch("/api/habits/update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: id, name: name, requiredTime: parseFloat(time) })
    })
    .then(res => res.json())
    .then(data => { if (data.success) window.location.reload(); })
    .catch(err => console.error(err));
}

document.getElementById("confirmDeleteButton").addEventListener("click", () => {
    if (!currentDeleteTargetId) return;
    fetch(`/api/habits/${currentDeleteTargetId}`, { method: "DELETE" })
    .then(res => res.json())
    .then(data => { if (data.success) window.location.reload(); })
    .catch(err => console.error("[Delete Routine Error]:", err));
});
</script>

<%- include('partials/footer') %>